# Local IDE / tool state
.claude/
.letta/
.vscode/
.idea/
*.swp
.DS_Store

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.python-version
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Data — gitignored by default; explicit subdirs added later via git add -f if small
# Note: leading slash so this only matches the top-level data/ directory,
# not nested ones like microbe_model/data/ (a Python subpackage).
/data/
*.h5
*.fasta
*.fna
*.faa
*.gbk
*.gbff

# Big binary data is gitignored, but allow it under reference_data/ for
# small precomputed reference parquets we want to ship.
*.parquet
*.npz
!reference_data/*.parquet
!reference_data/*.npz

# Model artifacts
checkpoints/
runs/
wandb/
*.pt
*.ckpt
*.safetensors

# Auto-generated paper tables that depend on data files
# (keep table generator + source; tables themselves can be regenerated)
# Note: we DO commit paper/tables/ as the latest snapshot for reviewers,
# but they should never be hand-edited.

# Notebooks
.ipynb_checkpoints/

# Env / secrets
.env
.env.local
*.key
